# Включение RCON (удалённой консоли)
enable-rcon=true

# Порт RCON. Должен совпадать с RCON_PORT из .env
rcon.port=25575

# Пароль RCON. Должен совпадать с RCON_PASSWORD из .env
rcon.password=your_super_secret_password_here

# Разрешить использование командных блоков (опционально)
# enable-command-block=true
